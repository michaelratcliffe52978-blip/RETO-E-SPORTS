<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.programacion.Vista.CRUDJugadores">
    <children>
        <SplitPane dividerPositions="0.6" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Listado de Jugadores">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="🔍" />
                                <TextField fx:id="txtBusqueda" promptText="Buscar por nickname..." HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <TableView fx:id="tablaJugadores" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colNickname" prefWidth="100.0" text="Nickname" />
                                <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre Real" />
                                <TableColumn fx:id="colNacionalidad" prefWidth="100.0" text="Nacionalidad" />
                                <TableColumn fx:id="colSueldo" prefWidth="80.0" text="Sueldo" />
                                <TableColumn fx:id="colFecha" prefWidth="100.0" text="F. Nacimiento" />
                                <TableColumn fx:id="colRol" prefWidth="100.0" text="Rol" />
                                <TableColumn fx:id="colEquipo" prefWidth="120.0" text="Equipo" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                </VBox>

                <VBox spacing="15.0" style="-fx-background-color: #f4f4f4;">
                    <children>
                        <Label text="Detalles del Jugador">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Separator prefWidth="200.0" />

                        <GridPane vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="90.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="160.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="ID (Auto):" />
                                <TextField fx:id="txtId" editable="false" style="-fx-background-color: #e0e0e0;" GridPane.columnIndex="1" />

                                <Label text="Nombre:" GridPane.rowIndex="1" />
                                <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Apellido:" GridPane.rowIndex="2" />
                                <TextField fx:id="txtApellido" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Nickname:" GridPane.rowIndex="3" />
                                <TextField fx:id="txtNickname" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Nacionalidad:" GridPane.rowIndex="4" />
                                <TextField fx:id="txtNacionalidad" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label text="Sueldo:" GridPane.rowIndex="5" />
                                <TextField fx:id="txtSueldo" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                <Label text="Fecha Nac.:" GridPane.rowIndex="6" />
                                <DatePicker fx:id="dateFechaNac" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                <Label text="Rol:" GridPane.rowIndex="7" />
                                <ComboBox fx:id="comboRol" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                <Label text="Equipo:" GridPane.rowIndex="8" />
                                <ComboBox fx:id="comboEquipo" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                            </children>
                        </GridPane>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button fx:id="btnGuardar" maxWidth="1.7976931348623157E308" onAction="#onGuardarClick" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="💾 GUARDAR / ACTUALIZAR">
                                    <font><Font name="System Bold" size="12.0" /></font></Button>
                                <Button fx:id="btnNuevo" maxWidth="1.7976931348623157E308" onAction="#onLimpiarClick" text="➕ Nuevo (Limpiar)" />
                                <Button fx:id="btnEliminar" maxWidth="1.7976931348623157E308" onAction="#onEliminarClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="🗑 ELIMINAR SELECCIÓN" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button fx:id="btnVolver" maxWidth="1.7976931348623157E308" onAction="#onAtras" style="-fx-background-color: black; -fx-text-fill: white;" text="VOLVER" />
                            </children>
                            <padding><Insets top="10.0" /></padding>
                        </VBox>
                    </children>
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>