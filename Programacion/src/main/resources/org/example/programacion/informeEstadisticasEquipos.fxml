<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.programacion.Vista.EstadisticasEquipos">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="📊 Estadísticas Globales de Equipos" textFill="#e57db9">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>

                <TableView fx:id="tablaEstadisticas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="150.0" text="Equipo" />
                        <TableColumn fx:id="colFundacion" prefWidth="100.0" text="Fundación" />
                        <TableColumn fx:id="colNumJugadores" prefWidth="100.0" text="Jugadores" />
                        <TableColumn fx:id="colSueldoMax" prefWidth="100.0" text="Sueldo Máx" />
                        <TableColumn fx:id="colSueldoMin" prefWidth="100.0" text="Sueldo Mín" />
                        <TableColumn fx:id="colSueldoMedio" prefWidth="100.0" text="Sueldo Medio" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button onAction="#onVolver" text="VOLVER" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
