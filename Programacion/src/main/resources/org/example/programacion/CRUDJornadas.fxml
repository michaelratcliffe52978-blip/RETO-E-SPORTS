<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.programacion.Controladores.JornadaController">
    <children>
        <SplitPane dividerPositions="0.6" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <children>
                        <Label text="Calendario de Jornadas" textFill="#e57bd9">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <TableView fx:id="tablaJornadas" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colNumero" prefWidth="100.0" text="Nº Jornada" />
                                <TableColumn fx:id="colFecha" prefWidth="150.0" text="Fecha" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="15.0" style="-fx-background-color: #f4f4f4;">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label text="Detalles de Jornada" textFill="#e57bd9">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Separator />
                        <GridPane vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="80.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="170.0" />
                            </columnConstraints>
                            <children>
                                <Label text="ID:" textFill="#e57bd9" />
                                <TextField fx:id="txtId" editable="false" style="-fx-background-color: #e0e0e0;" GridPane.columnIndex="1" />

                                <Label text="Número:" textFill="#e57bd9" GridPane.rowIndex="1" />
                                <TextField fx:id="txtNumero" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Fecha:" textFill="#e57bd9" GridPane.rowIndex="2" />
                                <DatePicker fx:id="dateFecha" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            </children>
                     <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                     </rowConstraints>
                        </GridPane>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button fx:id="btnGuardar" maxWidth="Infinity" onAction="#onGuardar" style="-fx-background-color: #e859d9; -fx-text-fill: white;" text="💾 GUARDAR JORNADA">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Button>
                                <Button fx:id="btnLimpiar" maxWidth="Infinity" onAction="#onLimpiar" text="➕ Nueva / Limpiar" />
                                <Button fx:id="btnEliminar" maxWidth="Infinity" onAction="#onEliminar" style="-fx-background-color: #e859d9; -fx-text-fill: white;" text="🗑 ELIMINAR" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#onVolver" style="-fx-background-color: #e57bd9; -fx-text-fill: white;" text="VOLVER" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
