<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.programacion.Vista.CRUDUsuarios">
    <children>
        <SplitPane dividerPositions="0.6" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <children>
                        <Label text="Gestión de Usuarios del Sistema">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colUser" prefWidth="150.0" text="Nombre de Usuario" />
                                <TableColumn fx:id="colRol" prefWidth="100.0" text="Rol / Tipo" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="15.0" style="-fx-background-color: #f4f4f4;">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label text="Detalles de Cuenta">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Separator />
                        <GridPane vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="80.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="170.0" />
                            </columnConstraints>
                            <children>
                                <Label text="ID Usuario:" />
                                <TextField fx:id="txtId" editable="false" style="-fx-background-color: #e0e0e0;" GridPane.columnIndex="1" />

                                <Label text="Username:" GridPane.rowIndex="1" />
                                <TextField fx:id="txtUsername" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Password:" GridPane.rowIndex="2" />
                                <PasswordField fx:id="txtPassword" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Rol:" GridPane.rowIndex="3" />
                                <ComboBox fx:id="comboRol" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                            </children>
                        </GridPane>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button maxWidth="Infinity" onAction="#onGuardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="💾 GUARDAR / ACTUALIZAR">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Button>
                                <Button maxWidth="Infinity" onAction="#onLimpiar" text="➕ Nuevo Usuario" />
                                <Button maxWidth="Infinity" onAction="#onEliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="🗑 ELIMINAR" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#onVolver" style="-fx-background-color: black; -fx-text-fill: white;" text="VOLVER" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>