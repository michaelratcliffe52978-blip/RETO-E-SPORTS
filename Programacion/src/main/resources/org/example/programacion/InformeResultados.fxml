<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.programacion.Vista.InformeResultados">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="HISTORIAL DE RESULTADOS">
            <font><Font name="System Bold" size="22.0" /></font>
        </Label>

        <TableView fx:id="tablaResultados" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colJornada" prefWidth="80.0" text="Jornada" />
                <TableColumn fx:id="colLocal" prefWidth="150.0" text="Local" />
                <TableColumn fx:id="colMarcador" prefWidth="100.0" text="Resultado" />
                <TableColumn fx:id="colVisitante" prefWidth="150.0" text="Visitante" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button onAction="#onVolver" style="-fx-background-color: black; -fx-text-fill: white;" text="VOLVER AL MENÚ" />
            </children>
        </HBox>
    </children>
</VBox>