<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.programacion.Vista.CRUDEquipos">
    <children>
        <SplitPane dividerPositions="0.6" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Gestión de Equipos" textFill="#e57bd9">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <TableView fx:id="tablaEquipos" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="colNombre" prefWidth="250.0" text="Nombre del Equipo" />
                                <TableColumn fx:id="colFecha" prefWidth="150.0" text="Fecha Fundación" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>

                <VBox spacing="15.0" style="-fx-background-color: #f4f4f4;">
                    <children>
                        <Label text="Detalles del Equipo" textFill="#e57bd9">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Separator prefWidth="200.0" />

                        <GridPane vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="ID Equipo:" textFill="#e57bd9" />
                                <TextField fx:id="txtId" editable="false" promptText="Autogenerado" style="-fx-background-color: #e0e0e0;" GridPane.columnIndex="1" />

                                <Label text="Nombre:" textFill="#e57bd9" GridPane.rowIndex="1" />
                                <TextField fx:id="txtNombre" promptText="Nombre del equipo" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Fundación:" textFill="#e57bd9" GridPane.rowIndex="2" />
                                <DatePicker fx:id="dateFecha" prefWidth="200.0" promptText="Seleccionar fecha" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            </children>
                        </GridPane>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button maxWidth="1.7976931348623157E308" onAction="#onGuardarClick" style="-fx-background-color: #e859d9; -fx-text-fill: white;" text="💾 GUARDAR / ACTUALIZAR">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Button>
                                <Button maxWidth="1.7976931348623157E308" onAction="#onLimpiarClick" text="➕ NUEVO EQUIPO" />
                                <Button maxWidth="1.7976931348623157E308" onAction="#onEliminarClick" style="-fx-background-color: #e859d9; -fx-text-fill: white;" text="🗑 ELIMINAR SELECCIÓN" />
                                <Button fx:id="btnInforme" maxWidth="1.7976931348623157E308" onAction="#onGenerarInformeClick" style="-fx-background-color: #e859d9; -fx-text-fill: white;" text="📊 GENERAR INFORME EQUIPO" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button maxWidth="1.7976931348623157E308" onAction="#onAtras" style="-fx-background-color: #e57bd9; -fx-text-fill: white;" text="VOLVER AL MENÚ" />
                            </children>
                            <padding>
                                <Insets top="20.0" />
                            </padding>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
